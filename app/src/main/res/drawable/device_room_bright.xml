<?xml version="1.0" encoding="utf-8"?>
<!--
    开灯模式的房间背景：从上到下的黄白渐变 + 金色边框。
    Java 代码根据 LightCallback 的结果动态切换 bright/dark 背景。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient android:angle="270" android:startColor="@color/device_bright_surface" android:endColor="@color/device_bright" />
    <corners android:radius="22dp" />
    <stroke android:width="1dp" android:color="#E7C858" />
</shape>