<?xml version="1.0" encoding="utf-8"?>
<!--
    卡片背景形状：白色圆角矩形 + 灰色边框。
    用于主页面中每个区域（连接区、灯光区、计时区、日志区）的容器背景。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/card_background" />              <!-- 填充色：白色 -->
    <corners android:radius="16dp" />                               <!-- 圆角半径：16dp -->
    <stroke android:width="1dp" android:color="@color/divider" /> <!-- 边框：1dp 灰色 -->
    <padding android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp" />
</shape>
